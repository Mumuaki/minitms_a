# =============================================================================
# MiniTMS — Environment Variables Template
# =============================================================================
# Скопируйте этот файл:
#   cp .env.example backend/.env        (для локальной разработки)
#   cp .env.example .env.remote         (для удалённого VPS)
#   cp .env.example .env.production     (для production)
#
# Замените все значения CHANGE_ME на реальные.
# НИКОГДА не коммитьте файлы с реальными паролями в Git!
# =============================================================================

# === Database (PostgreSQL) ===
DB_PASSWORD=CHANGE_ME
DB_HOST=postgres
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/mini-tms

# === Redis ===
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# === JWT / Security ===
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME

# === GPS Dozor ===
GPS_DOZOR_URL=https://a1.gpsguard.eu/api/v1/vehicle/
GPS_DOZOR_USERNAME=CHANGE_ME
GPS_DOZOR_PASSWORD=CHANGE_ME

# === Trans.eu Scraping ===
TRANS_EU_USERNAME=CHANGE_ME
TRANS_EU_PASSWORD=CHANGE_ME
HEADLESS_MODE=True

# === SMTP (Email) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=CHANGE_ME

# === Google Sheets ===
# JSON-строка с содержимым service account credentials
GOOGLE_SHEETS_CREDENTIALS=CHANGE_ME
GOOGLE_SHEETS_ID=CHANGE_ME

# === Application ===
DEBUG=False
CORS_ORIGINS=http://localhost,http://localhost:5173

# === Browser (Scraping Worker) ===
BROWSER_PROFILE_DIR=/workspace/browser_profile
