# --- App Settings ---
APP_NAME=MiniTMS
DEBUG=True

# --- Security ---
SECRET_KEY=change_this_secret_key_minimum_32_characters_long_for_security
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Database ---
# Для локальной разработки:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mini-tms

# Для Docker:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/mini-tms

# Для удаленного VPS (замените YOUR_VPS_IP):
# DATABASE_URL=postgresql://postgres:your_password@YOUR_VPS_IP:5432/mini-tms

# --- Redis ---
# Для локальной разработки:
REDIS_URL=redis://localhost:6379/0

# Для Docker:
# REDIS_URL=redis://redis:6379/0

# Для удаленного VPS:
# REDIS_URL=redis://YOUR_VPS_IP:6379/0

# --- Trans.eu Scraping ---
TRANS_EU_USERNAME=your-username
TRANS_EU_PASSWORD=your-password
HEADLESS_MODE=True

# --- GPS Dozor Credentials ---
GPS_DOZOR_URL=https://a1.gpsguard.eu/api/v1/vehicle/
GPS_DOZOR_USERNAME=your-email@example.com
GPS_DOZOR_PASSWORD=your-gps-password

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# --- Application ---
DEBUG=False
